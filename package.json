{
  "name": "node-seo",
  "version": "1.0.0",
  "description": "React + Vite SEO utility for managing head tags, structured data, and SEO validation with a clean API and build-time plugin support",
  "type": "module",

  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./vite-plugin": {
      "import": "./dist/vite-plugin/index.js",
      "require": "./dist/vite-plugin/index.cjs"
    }
  },

  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest"
  },

  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "vite": "^5 || ^6 || ^7"
  },

  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "typescript": "5.8.3",
    "fs": "^0.0.1-security",
    "path": "^0.12.7",
    "tsup": "^8.5.1",
    "vite": "^8.0.16"
  }
}