{
  "name": "seoplus",
  "version": "1.0.3",
  "description": "React + Vite SEO utility for managing meta tags, Open Graph, Twitter cards, JSON-LD schema, sitemap generation, and real-time SEO validation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./vite-plugin": {
      "import": "./dist/vite-plugin/index.js",
      "require": "./dist/vite-plugin/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "vite": "^5 || ^6 || ^7"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "typescript": "5.8.3",
    "tsup": "^8.5.1",
    "vite": "^8.0.16",
    "fs": "^0.0.1-security",
    "path": "^0.12.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Loki-Xer/seoplus.git"
  },
  "homepage": "https://github.com/Loki-Xer/seoplus#readme",
  "bugs": {
    "url": "https://github.com/Loki-Xer/seoplus/issues"
  },
  "keywords": [
    "react",
    "seo",
    "vite",
    "meta-tags",
    "json-ld",
    "sitemap",
    "robots",
    "typescript"
  ],
  "license": "MIT"
}
